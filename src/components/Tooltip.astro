---
import Link from "./Link.astro";

interface Props {
  to?: string;
}

const { to = "" } = Astro.props;
const id = `tooltip-${Math.random().toString(36).slice(2, 9)}`;
---

<span class="tooltip-root relative !my-0 inline-flex">
  <span
    class="tooltip-trigger border-b-2 border-dotted border-fuchsia-700"
    style={`anchor-name: --${id}`}
    data-tooltip-id={id}
    data-to={to}
  >
    {to ? (
      <Link class="no-underline" style="text-wrap: nowrap" to={to}>
        <slot name="main" />
      </Link>
    ) : (
      <slot name="main" />
    )}
    {to && (
      <span class="tooltip-mobile-main hidden font-medium text-orange-600 dark:text-orange-400">
        <slot name="main" />
      </span>
    )}
  </span>
  <span
    popover="manual"
    id={id}
    class="tooltip-popup m-0 w-max max-w-[250px] rounded bg-fuchsia-700 p-2 text-center text-sm leading-5 text-white"
    style={`position-anchor: --${id}; position: fixed; inset: auto; position-area: block-start center; margin-bottom: 4px;`}
  >
    {to ? (
      <a
        rel="noreferrer"
        class="tooltip-mobile-link hidden text-white underline"
        href={to}
        target="_blank"
      >
        <slot name="hover" />
      </a>
    ) : null}
    <span class="tooltip-hover-content">
      <slot name="hover" />
    </span>
  </span>
</span>

<script>
  document.querySelectorAll<HTMLElement>(".tooltip-root").forEach((root) => {
    const trigger = root.querySelector<HTMLElement>(".tooltip-trigger");
    const popup = root.querySelector<HTMLElement>(".tooltip-popup");
    const to = trigger?.dataset.to || "";
    const mobileMain = root.querySelector<HTMLElement>(".tooltip-mobile-main");
    const mobileLink = root.querySelector<HTMLElement>(".tooltip-mobile-link");
    const hoverContent = root.querySelector<HTMLElement>(
      ".tooltip-hover-content"
    );

    if (!trigger || !popup) return;

    const isMobile =
      /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(
        navigator.userAgent
      );

    if (isMobile && to) {
      const desktopLink = trigger.querySelector("a");
      if (desktopLink) desktopLink.style.display = "none";
      if (mobileMain) mobileMain.classList.remove("hidden");
      if (mobileLink) mobileLink.classList.remove("hidden");
      if (hoverContent) hoverContent.classList.add("hidden");
    } else {
      if (mobileMain) mobileMain.remove();
      if (mobileLink) mobileLink.remove();
    }

    const show = () => {
      popup.showPopover();
    };

    const hide = () => {
      popup.hidePopover();
    };

    trigger.addEventListener("mouseenter", show);
    trigger.addEventListener("mouseleave", hide);
    trigger.addEventListener("touchstart", show);

    document.addEventListener(
      "touchstart",
      (event) => {
        if (root.contains(event.target as Node)) return;
        hide();
      },
      { capture: true, passive: true }
    );
  });
</script>
