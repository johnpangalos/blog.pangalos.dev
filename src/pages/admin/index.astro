---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Admin">
  <div class="pt-6">
    <div class="flex items-center justify-between pb-6">
      <h2 class="font-display text-amber-600 dark:text-amber-500 text-4xl font-bold">
        Admin
      </h2>
      <form method="POST" action="/api/auth/logout">
        <button
          type="submit"
          class="rounded bg-stone-200 dark:bg-stone-700 px-4 py-2 text-sm font-bold hover:bg-stone-300 dark:hover:bg-stone-600"
        >
          Logout
        </button>
      </form>
    </div>
    <p>Welcome to the admin panel.</p>
  </div>
</BaseLayout>
