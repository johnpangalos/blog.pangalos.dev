---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { isAuthenticated } from "../../lib/auth";

if (!(await isAuthenticated(Astro))) {
  return Astro.redirect("/admin/login");
}
---

<BaseLayout title="New Post">
  <div class="mt-16">
    <div class="flex items-center justify-between">
      <h1 class="font-display text-3xl font-bold">New Post</h1>
      <a
        href="/admin"
        class="rounded bg-stone-200 px-3 py-1 text-sm hover:bg-stone-300 dark:bg-stone-700 dark:hover:bg-stone-600"
      >
        Back
      </a>
    </div>

    <form id="post-form" class="mt-8 space-y-4">
      <div>
        <label for="title" class="block text-sm font-bold">Title</label>
        <input
          type="text"
          id="title"
          name="title"
          required
          class="mt-1 w-full rounded border border-stone-300 bg-white px-3 py-2 text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
          placeholder="the.post.title"
        />
      </div>

      <div>
        <label for="author" class="block text-sm font-bold">Author</label>
        <input
          type="text"
          id="author"
          name="author"
          required
          value="John Pangalos"
          class="mt-1 w-full rounded border border-stone-300 bg-white px-3 py-2 text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
        />
      </div>

      <div>
        <label for="date" class="block text-sm font-bold">Date</label>
        <input
          type="text"
          id="date"
          name="date"
          required
          class="mt-1 w-full rounded border border-stone-300 bg-white px-3 py-2 text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
          placeholder="March 20, 2026"
        />
      </div>

      <div>
        <label for="description" class="block text-sm font-bold"
          >Description</label
        >
        <textarea
          id="description"
          name="description"
          required
          rows="2"
          class="mt-1 w-full rounded border border-stone-300 bg-white px-3 py-2 text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
          placeholder="A short description of the post..."></textarea>
      </div>

      <div>
        <label for="tags" class="block text-sm font-bold"
          >Tags (comma-separated)</label
        >
        <input
          type="text"
          id="tags"
          name="tags"
          class="mt-1 w-full rounded border border-stone-300 bg-white px-3 py-2 text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
          placeholder="web, javascript, blogging"
        />
      </div>

      <div>
        <label for="categories" class="block text-sm font-bold"
          >Categories (comma-separated)</label
        >
        <input
          type="text"
          id="categories"
          name="categories"
          class="mt-1 w-full rounded border border-stone-300 bg-white px-3 py-2 text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
          placeholder="web"
        />
      </div>

      <div>
        <label for="content" class="block text-sm font-bold"
          >Content (Markdown)</label
        >
        <textarea
          id="content"
          name="content"
          required
          rows="16"
          class="mt-1 w-full rounded border border-stone-300 bg-white px-3 py-2 font-mono text-sm text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
          placeholder="Write your blog post in Markdown..."></textarea>
      </div>

      <div id="status" class="text-sm"></div>

      <button
        type="submit"
        class="rounded bg-fuchsia-700 px-4 py-2 font-bold text-white hover:bg-fuchsia-800 dark:bg-fuchsia-600 dark:hover:bg-fuchsia-700"
      >
        Publish
      </button>
    </form>
  </div>

  <script>
    import { actions } from "astro:actions";

    const form = document.getElementById("post-form") as HTMLFormElement;
    const status = document.getElementById("status")!;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      status.textContent = "Publishing...";
      status.className = "text-sm text-stone-500";

      const formData = new FormData(form);
      const tagsRaw = (formData.get("tags") as string) || "";
      const categoriesRaw = (formData.get("categories") as string) || "";

      const tags = tagsRaw
        .split(",")
        .map((t) => t.trim())
        .filter(Boolean);
      const categories = categoriesRaw
        .split(",")
        .map((c) => c.trim())
        .filter(Boolean);

      const { data, error } = await actions.blog.create({
        title: formData.get("title") as string,
        author: formData.get("author") as string,
        date: formData.get("date") as string,
        description: formData.get("description") as string,
        tags,
        categories,
        content: formData.get("content") as string,
      });

      if (error) {
        status.textContent = `Error: ${error.message}`;
        status.className = "text-sm text-red-600 dark:text-red-400";
        return;
      }

      status.textContent = "Published!";
      status.className = "text-sm text-green-600 dark:text-green-400";
      window.location.href = `/blog/${data.slug}`;
    });
  </script>
</BaseLayout>
