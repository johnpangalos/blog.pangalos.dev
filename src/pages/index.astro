---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import { listPosts } from "../lib/blog";

const siteTitle = "some.blog.or.whatever";

const staticPosts = (await getCollection("blog")).map((p) => ({
  id: p.id,
  title: p.data.title,
  date: p.data.date,
  description: p.data.description,
}));

const dynamicPosts = (await listPosts(Astro)).map((p) => ({
  id: p.slug,
  title: p.title,
  date: p.date,
  description: p.description,
}));

const posts = [...staticPosts, ...dynamicPosts].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
---

<BaseLayout title={siteTitle}>
  <h2
    class="font-display text-amber-600 dark:text-amber-500 pt-6 pb-4 text-4xl font-bold"
  >
    Articles
  </h2>
  <ul class="space-y-1 pb-8">
    {posts.map((post) => (
      <li>
        <h3
          class="pb-2 text-2xl font-bold font-display text-amber-600 dark:text-amber-500"
        >
          {post.title}
        </h3>
        <p class="pb-1 font-bold">{post.date}</p>
        <p class="pb-2">{post.description}</p>
        <div class="flex justify-end">
          <Button to={`blog/${post.id}`}>Go to article</Button>
        </div>
      </li>
    ))}
  </ul>
</BaseLayout>
