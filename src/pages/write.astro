---
import BaseLayout from "../layouts/BaseLayout.astro";

const kv = Astro.locals.runtime.env.DRAFTS;
const token = Astro.cookies.get("write_token")?.value;
const session = token ? await kv.get(`session:${token}`) : null;
if (!session) {
  return Astro.redirect("/login");
}

// Check if editing an existing draft
const draftId = Astro.url.searchParams.get("draft");
---

<BaseLayout title="Write">
  <div class="py-6">
    <div class="flex items-center justify-between pb-4">
      <h2
        class="font-display text-amber-600 dark:text-amber-500 text-3xl font-bold"
      >
        Write
      </h2>
      <a
        href="/drafts"
        class="text-fuchsia-700 underline dark:text-fuchsia-500"
      >
        View drafts
      </a>
    </div>

    <!-- Frontmatter fields -->
    <details class="mb-4 rounded border border-stone-300 dark:border-stone-600">
      <summary class="cursor-pointer px-3 py-2 font-bold"
        >Post metadata</summary
      >
      <div class="space-y-3 px-3 pb-3">
        <div>
          <label for="fm-title" class="block text-sm font-bold">Title</label>
          <input
            type="text"
            id="fm-title"
            class="w-full rounded border border-stone-300 bg-white px-2 py-1 text-sm text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
            placeholder="my.post.title"
          />
        </div>
        <div>
          <label for="fm-description" class="block text-sm font-bold"
            >Description</label
          >
          <textarea
            id="fm-description"
            rows="2"
            class="w-full rounded border border-stone-300 bg-white px-2 py-1 text-sm text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
            placeholder="A short description of the post"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="fm-tags" class="block text-sm font-bold"
              >Tags (comma-separated)</label
            >
            <input
              type="text"
              id="fm-tags"
              class="w-full rounded border border-stone-300 bg-white px-2 py-1 text-sm text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
              placeholder="web, css"
            />
          </div>
          <div>
            <label for="fm-categories" class="block text-sm font-bold"
              >Categories</label
            >
            <input
              type="text"
              id="fm-categories"
              class="w-full rounded border border-stone-300 bg-white px-2 py-1 text-sm text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
              placeholder="web"
            />
          </div>
        </div>
      </div>
    </details>

    <!-- Editor -->
    <textarea
      id="editor"
      class="min-h-[50vh] w-full rounded border border-stone-300 bg-white p-3 font-mono text-sm text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
      placeholder="Start writing your post in markdown..."
      spellcheck="true"></textarea>

    <!-- Actions -->
    <div class="flex gap-2 pt-3">
      <button
        id="save-btn"
        class="rounded bg-fuchsia-700 px-4 py-2 text-sm font-bold text-white dark:bg-fuchsia-600"
      >
        Save draft
      </button>
      <button
        id="publish-btn"
        class="rounded bg-amber-600 px-4 py-2 text-sm font-bold text-white dark:bg-amber-500"
      >
        Create PR
      </button>
    </div>
    <p id="status" class="pt-2 text-sm"></p>
  </div>

  <script define:vars={{ draftId }}>
    const editor = document.getElementById("editor");
    const titleInput = document.getElementById("fm-title");
    const descInput = document.getElementById("fm-description");
    const tagsInput = document.getElementById("fm-tags");
    const catsInput = document.getElementById("fm-categories");
    const saveBtn = document.getElementById("save-btn");
    const publishBtn = document.getElementById("publish-btn");
    const status = document.getElementById("status");

    let currentDraftId = draftId;

    function getFrontmatter() {
      return {
        author: "John Pangalos",
        title: titleInput.value || "Untitled",
        date: new Date().toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        }),
        description: descInput.value || "",
        tags: tagsInput.value
          .split(",")
          .map((t) => t.trim())
          .filter(Boolean),
        categories: catsInput.value
          .split(",")
          .map((c) => c.trim())
          .filter(Boolean),
      };
    }

    // Load existing draft if editing
    if (currentDraftId) {
      fetch(`/api/drafts/${currentDraftId}`)
        .then((r) => r.json())
        .then((data) => {
          editor.value = data.content || "";
          if (data.frontmatter) {
            titleInput.value = data.frontmatter.title || "";
            descInput.value = data.frontmatter.description || "";
            tagsInput.value = (data.frontmatter.tags || []).join(", ");
            catsInput.value = (data.frontmatter.categories || []).join(", ");
          }
        })
        .catch(() => {
          status.textContent = "Failed to load draft";
        });
    }

    // Auto-save every 30 seconds
    let autoSaveTimer;
    editor.addEventListener("input", () => {
      clearTimeout(autoSaveTimer);
      autoSaveTimer = setTimeout(() => saveDraft(true), 30000);
    });

    async function saveDraft(silent = false) {
      const res = await fetch("/api/drafts", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          id: currentDraftId,
          title: titleInput.value || "Untitled",
          content: editor.value,
          frontmatter: getFrontmatter(),
        }),
      });

      if (res.ok) {
        const data = await res.json();
        currentDraftId = data.id;
        // Update URL without reload
        const url = new URL(window.location);
        url.searchParams.set("draft", currentDraftId);
        history.replaceState(null, "", url);
        if (!silent) {
          status.textContent = "Draft saved!";
          setTimeout(() => (status.textContent = ""), 2000);
        }
      } else {
        status.textContent = "Failed to save draft";
      }
    }

    saveBtn.addEventListener("click", () => saveDraft(false));

    publishBtn.addEventListener("click", async () => {
      if (!titleInput.value) {
        status.textContent = "Please set a title before publishing";
        return;
      }

      if (!confirm("Create a PR for this post?")) {
        return;
      }

      // Save first to ensure latest content is in KV
      await saveDraft(true);

      status.textContent = "Publishing...";
      const res = await fetch(`/api/drafts/${currentDraftId}/publish`, {
        method: "POST",
      });

      if (res.ok) {
        const data = await res.json();
        status.innerHTML = `PR created! <a href="${data.pr_url}" target="_blank" class="underline text-fuchsia-700 dark:text-fuchsia-500">View pull request</a>`;
      } else {
        const err = await res.json();
        status.textContent = `Publish failed: ${err.error}`;
      }
    });
  </script>
</BaseLayout>
