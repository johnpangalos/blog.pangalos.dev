---
import BaseLayout from "../layouts/BaseLayout.astro";

const kv = Astro.locals.runtime.env.DRAFTS;
const token = Astro.cookies.get("write_token")?.value;
const session = token ? await kv.get(`session:${token}`) : null;
if (!session) {
  return Astro.redirect("/login");
}
---

<BaseLayout title="Write">
  <div class="py-6">
    <div class="flex items-center justify-between pb-4">
      <h2
        class="font-display text-amber-600 dark:text-amber-500 text-3xl font-bold"
      >
        Write
      </h2>
      <a
        href="/drafts"
        class="text-fuchsia-700 underline dark:text-fuchsia-500"
      >
        View drafts
      </a>
    </div>

    <!-- Frontmatter fields -->
    <details class="mb-4 rounded border border-stone-300 dark:border-stone-600">
      <summary class="cursor-pointer px-3 py-2 font-bold"
        >Post metadata</summary
      >
      <div class="space-y-3 px-3 pb-3">
        <div>
          <label for="fm-title" class="block text-sm font-bold">Title</label>
          <input
            type="text"
            id="fm-title"
            class="w-full rounded border border-stone-300 bg-white px-2 py-1 text-sm text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
            placeholder="my.post.title"
          />
        </div>
        <div>
          <label for="fm-description" class="block text-sm font-bold"
            >Description</label
          >
          <textarea
            id="fm-description"
            rows="2"
            class="w-full rounded border border-stone-300 bg-white px-2 py-1 text-sm text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
            placeholder="A short description of the post"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="fm-tags" class="block text-sm font-bold"
              >Tags (comma-separated)</label
            >
            <input
              type="text"
              id="fm-tags"
              class="w-full rounded border border-stone-300 bg-white px-2 py-1 text-sm text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
              placeholder="web, css"
            />
          </div>
          <div>
            <label for="fm-categories" class="block text-sm font-bold"
              >Categories</label
            >
            <input
              type="text"
              id="fm-categories"
              class="w-full rounded border border-stone-300 bg-white px-2 py-1 text-sm text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
              placeholder="web"
            />
          </div>
        </div>
      </div>
    </details>

    <!-- Editor -->
    <textarea
      id="editor"
      class="min-h-[50vh] w-full rounded border border-stone-300 bg-white p-3 font-mono text-sm text-stone-900 dark:border-stone-600 dark:bg-stone-800 dark:text-white"
      placeholder="Start writing your post in markdown..."
      spellcheck="true"></textarea>

    <!-- Actions -->
    <div class="flex gap-2 pt-3">
      <button
        id="save-btn"
        class="rounded bg-fuchsia-700 px-4 py-2 text-sm font-bold text-white dark:bg-fuchsia-600"
      >
        Save draft
      </button>
      <button
        id="publish-btn"
        class="rounded bg-amber-600 px-4 py-2 text-sm font-bold text-white dark:bg-amber-500"
      >
        Create PR
      </button>
    </div>
    <p id="status" class="pt-2 text-sm"></p>
  </div>

  <script src="../scripts/write.ts"></script>
</BaseLayout>
